# Supabase project URL (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public API key (safe for browser use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used for metadata, sitemap, and canonical/hreflang tags
NEXT_PUBLIC_SITE_URL=https://alejandrosoza.ca

# Email address granted admin access to /admin
ADMIN_EMAIL=

# Resend API key for sending contact form notifications
RESEND_API_KEY=

# Cloudinary cloud name (Dashboard → Account Details)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Cloudinary API key — server-only
CLOUDINARY_API_KEY=

# Cloudinary API secret — server-only, never expose to the client
CLOUDINARY_API_SECRET=
